{
  "$schema": "https://opencode.ai/config.json",

  "agent": {
    "build": {
      "mode": "primary",
      "permission": {
        "edit": "ask",
        "bash": {
          "*": "ask",
          "git status": "allow",
          "git diff *": "allow",
          "git log *": "allow",
          "ls *": "allow",
          "cat *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "find *": "allow",
          "npm test": "allow",
          "npm run test *": "allow",
          "npm run typecheck": "allow",
          "go test *": "allow"
        }
      }
    },

    "plan": {
      "mode": "primary",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "cat *": "allow",
          "ls *": "allow",
          "git diff *": "allow",
          "git log *": "allow"
        }
      }
    },

    "researcher": {
      "mode": "subagent",
      "description": "FIC Phase 1 — Read-only codebase researcher. Uses explore subagent for file ops. Returns compacted summaries.",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "task": {
          "*": "deny",
          "explore": "allow",
          "general": "allow"
        },
        "bash": {
          "*": "deny",
          "grep *": "allow",
          "rg *": "allow",
          "find *": "allow",
          "ls *": "allow",
          "cat *": "allow",
          "fd *": "allow"
        }
      }
    },

    "planner": {
      "mode": "subagent",
      "description": "FIC Phase 2 — Creates precise phased implementation plans from research docs. Never writes code.",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "cat *": "allow",
          "ls *": "allow"
        }
      }
    }
  },

  "permission": {
    "skill": {
      "*": "allow"
    }
  }
}
